# Building The Future — environment variables
#
# Copy this file to `.env` (which is gitignored) and fill in the real values
# from the Supabase dashboard: Project settings → API.
#
# These are PUBLIC, client-safe keys — fine to ship to the browser. Supabase
# Row-Level Security policies are what enforce authorisation, not these keys.
# NEVER put the `service_role` key in here — that one is server-only.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...replace-with-your-anon-key
